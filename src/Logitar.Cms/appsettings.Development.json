{
  "Cors": {
    "AllowCredentials": true,
    "AllowedOrigins": [ "*" ],
    "AllowedMethods": [ "*" ],
    "AllowedHeaders": [ "*" ]
  },
  "EnableOpenApi": true,
  "GraphQL": {
    "EnableMetrics": true,
    "ExposeExceptionDetails": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "MigrateDatabase": true,
  "UseGraphQLAltair": true,
  "UseGraphQLGraphiQL": true,
  "UseGraphQLPlayground": true,
  "UseGraphQLVoyager": true
}

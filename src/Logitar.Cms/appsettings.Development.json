{
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173" ],
    "AllowedMethods": [ "GET", "POST", "PUT" ],
    "AllowedHeaders": [ "content-type" ]
  },
  "EnableOpenApi": true,
  "GraphQL": {
    "EnableMetrics": true,
    "ExposeExceptionDetails": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "MigrateDatabase": true,
  "UseGraphQLAltair": true,
  "UseGraphQLGraphiQL": true,
  "UseGraphQLPlayground": true,
  "UseGraphQLVoyager": true
}
